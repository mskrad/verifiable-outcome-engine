{
  "name": "verifiable-outcome-sdk",
  "version": "0.2.0",
  "description": "Build and verify outcomes with Verifiable Outcome Engine on Solana",
  "license": "MIT",
  "keywords": [
    "solana",
    "verifiable",
    "outcome",
    "raffle",
    "airdrop",
    "sdk"
  ],
  "homepage": "https://verifiableoutcome.online",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mskrad/verifiable-outcome-engine.git"
  },
  "type": "module",
  "main": "dist/sdk/index.js",
  "types": "dist/sdk/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/sdk/index.js",
      "types": "./dist/sdk/index.d.ts"
    }
  },
  "files": [
    "dist/sdk/index.js",
    "dist/sdk/index.d.ts",
    "dist/sdk/verify.js",
    "dist/sdk/verify.d.ts",
    "dist/sdk/artifact.js",
    "dist/sdk/artifact.d.ts",
    "dist/sdk/types.js",
    "dist/sdk/types.d.ts",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/sdk/cli.js",
    "build:artifact": "TS_NODE_PROJECT=tsconfig.json ts-node --esm --transpile-only scripts/build_artifact.ts",
    "replay": "TS_NODE_PROJECT=tsconfig.json ts-node --esm --transpile-only scripts/replay_verify.ts",
    "resolve:operator": "TS_NODE_PROJECT=tsconfig.json ts-node --esm --transpile-only scripts/resolve_operator.ts",
    "web": "node web/server.mjs"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.98.4"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "bn.js": "^5.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
