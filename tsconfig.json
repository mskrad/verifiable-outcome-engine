{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "noEmit": true,
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["scripts/**/*.ts", "sdk/**/*.ts"],
  "ts-node": {
    "esm": true,
    "experimentalResolver": true,
    "transpileOnly": true
  }
}
